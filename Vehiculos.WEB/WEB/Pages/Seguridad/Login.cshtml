@page
@model Web.Pages.Seguridad.LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-page py-5">
    <div class="container auth-container d-flex align-items-center">
        <div class="row w-100 align-items-center g-5">
            <div class="col-lg-6">
                <div class="auth-intro">
                    <span class="auth-badge">
                        <i class="bi bi-shield-lock-fill me-2"></i>Acceso seguro
                    </span>

                    <h1 class="auth-title">
                        Inicia sesión para administrar el
                        <span>módulo de vehículos</span>
                    </h1>

                    <p class="auth-subtitle">
                        Accede de forma segura al sistema para consultar, registrar, editar y administrar
                        la información vehicular desde una interfaz moderna, clara y ordenada.
                    </p>

                    <div class="auth-feature-list">
                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-person-check-fill"></i>
                            </div>
                            <div>
                                <strong>Acceso autenticado</strong>
                                <span>Ingreso mediante credenciales seguras y sesión protegida.</span>
                            </div>
                        </div>

                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-car-front-fill"></i>
                            </div>
                            <div>
                                <strong>Gestión centralizada</strong>
                                <span>Controla la información de vehículos desde un solo lugar.</span>
                            </div>
                        </div>

                        <div class="auth-feature-item">
                            <div class="auth-feature-icon">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div>
                                <strong>Sesión protegida</strong>
                                <span>La plataforma utiliza autenticación y autorización para mayor seguridad.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="auth-card">
                    <div class="auth-card-top">
                        <div class="auth-card-icon">
                            <i class="bi bi-person-circle"></i>
                        </div>
                        <h2>Bienvenido</h2>
                        <p>Ingresa tus credenciales para continuar</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
                    {
                        <div class="alert alert-danger auth-alert" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @Model.MensajeError
                        </div>
                    }

                    <form method="post" class="auth-form">
                        <div class="mb-3">
                            <label asp-for="CorreoElectronico" class="form-label auth-label">Correo electrónico</label>
                            <div class="auth-input-group">
                                <span class="auth-input-icon">
                                    <i class="bi bi-envelope-fill"></i>
                                </span>
                                <input asp-for="CorreoElectronico" class="form-control auth-input" placeholder="correo@ejemplo.com" />
                            </div>
                            <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Contrasenia" class="form-label auth-label">Contraseña</label>
                            <div class="auth-input-group">
                                <span class="auth-input-icon">
                                    <i class="bi bi-key-fill"></i>
                                </span>
                                <input asp-for="Contrasenia" type="password" class="form-control auth-input" placeholder="Ingresa tu contraseña" />
                            </div>
                            <span asp-validation-for="Contrasenia" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn auth-btn w-100">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Ingresar al sistema
                        </button>
                    </form>

                    <div class="auth-footer-note">
                        <i class="bi bi-lock-fill me-1"></i>
                        Acceso restringido únicamente a usuarios autenticados.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}