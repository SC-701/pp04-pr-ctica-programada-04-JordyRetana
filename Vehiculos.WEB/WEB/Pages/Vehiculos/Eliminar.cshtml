@page
@model Web.Pages.Vehiculos.EliminarModel
@{
    ViewData["Title"] = "Eliminar Vehículo";
}

<section class="vehicle-page">
    <div class="vehicle-wrapper">
        <div class="vehicle-hero">
            <div class="vehicle-hero-content">
                <div>
                    <span class="vehicle-kicker">
                        <i class="bi bi-trash3-fill me-2"></i>SC-701 · Módulo de Vehículos
                    </span>
                    <h1 class="vehicle-title">Eliminar Vehículo</h1>
                    <p class="vehicle-subtitle">
                        Revisa la información del registro antes de confirmar la eliminación.
                    </p>
                </div>
            </div>
        </div>

        <div class="form-wrapper">
            <div class="form-card">
                <div class="form-header">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <h2>Confirmación de eliminación</h2>
                    <p>Esta acción eliminará el registro seleccionado del sistema.</p>
                </div>

                <div class="form-body">
                    <div class="glass-card p-3 mb-4">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-exclamation-octagon-fill fs-3 text-danger"></i>
                            <div>
                                <div class="fw-bold text-white mb-1">Acción irreversible</div>
                                <div class="text-footer-muted">
                                    Verifica cuidadosamente la información antes de continuar, ya que el registro no podrá recuperarse.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="info-group mb-4">
                        <h3>Datos del vehículo</h3>

                        <div class="info-item">
                            <span class="info-label">Marca</span>
                            <span class="info-value">@Html.DisplayFor(m => m.vehiculo.Marca)</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Modelo</span>
                            <span class="info-value">@Html.DisplayFor(m => m.vehiculo.Modelo)</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Placa</span>
                            <span class="info-value">@Html.DisplayFor(m => m.vehiculo.Placa)</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Año</span>
                            <span class="info-value">@Html.DisplayFor(m => m.vehiculo.Anio)</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Color</span>
                            <span class="info-value">@Html.DisplayFor(m => m.vehiculo.Color)</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Correo del propietario</span>
                            <span class="info-value">@Html.DisplayFor(m => m.vehiculo.CorreoPropietario)</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Teléfono del propietario</span>
                            <span class="info-value">@Html.DisplayFor(m => m.vehiculo.TelefonoPropietario)</span>
                        </div>
                    </div>

                    <form method="post">
                        <div class="form-actions">
                            <a class="btn-form-secondary" asp-page="./Index">
                                <i class="bi bi-x-circle me-1"></i> Cancelar
                            </a>

                            <button type="submit" class="btn-form-danger">
                                <i class="bi bi-trash3 me-1"></i> Eliminar
                            </button>
                        </div>

                        <input type="hidden" asp-for="vehiculo.Marca" />
                        <input type="hidden" asp-for="vehiculo.Modelo" />
                        <input type="hidden" asp-for="vehiculo.Placa" />
                        <input type="hidden" asp-for="vehiculo.TelefonoPropietario" />
                        <input type="hidden" asp-for="vehiculo.CorreoPropietario" />
                        <input type="hidden" asp-for="vehiculo.Color" />
                        <input type="hidden" asp-for="vehiculo.Anio" />
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>