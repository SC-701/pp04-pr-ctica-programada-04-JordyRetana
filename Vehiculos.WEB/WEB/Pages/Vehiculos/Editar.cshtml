@page
@model Web.Pages.Vehiculos.EditarModel
@{
    ViewData["Title"] = "Editar Vehículo";
}

<section class="vehicle-page">
    <div class="vehicle-wrapper">
        <div class="vehicle-hero">
            <div class="vehicle-hero-content">
                <div>
                    <span class="vehicle-kicker">
                        <i class="bi bi-pencil-square me-2"></i>SC-701 · Módulo de Vehículos
                    </span>
                    <h1 class="vehicle-title">Editar Vehículo</h1>
                    <p class="vehicle-subtitle">
                        Actualiza la información del vehículo seleccionado dentro del sistema.
                    </p>
                </div>
            </div>
        </div>

        <div class="form-wrapper">
            <div class="form-card">
                <div class="form-header">
                    <i class="bi bi-pencil-square"></i>
                    <h2>Actualización de datos</h2>
                    <p>Modifica la información del vehículo y guarda los cambios realizados.</p>
                </div>

                <div class="form-body">
                    <div class="progress-bar-custom">
                        <div class="progress-fill" style="width: 100%;"></div>
                    </div>

                    <div class="glass-card p-3 mb-4">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-tools fs-3 text-warning"></i>
                            <div>
                                <div class="fw-bold text-white mb-1">Edición del registro</div>
                                <div class="text-footer-muted">
                                    Realiza únicamente los cambios necesarios y verifica los datos antes de guardar.
                                </div>
                            </div>
                        </div>
                    </div>

                    <form method="post">
                        <div class="form-section-title">Datos del vehículo</div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="marcas" class="form-label">Marca</label>
                                <select asp-for="marcaSeleccionada"
                                        class="form-select"
                                        asp-items="Model.marcas"
                                        id="marcas"
                                        onchange="fetchModelos()">
                                    <option value="">Seleccione una marca</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="modelos" class="form-label">Modelo</label>
                                <select asp-for="modeloSeleccionado"
                                        class="form-select"
                                        asp-items="Model.modelos"
                                        id="modelos">
                                    <option value="">Seleccione un modelo</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="vehiculo.Placa"></label>
                                <input class="form-control"
                                       asp-for="vehiculo.Placa"
                                       id="placa"
                                       maxlength="7"
                                       placeholder="Ej: 123-ABC"
                                       autocomplete="off"
                                       style="text-transform: uppercase;" />
                                <span class="text-danger small" asp-validation-for="vehiculo.Placa"></span>
                                <div class="form-text">Formato requerido: ###-ABC</div>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="vehiculo.Anio"></label>
                                <input class="form-control"
                                       asp-for="vehiculo.Anio"
                                       type="number"
                                       min="1900"
                                       max="2100" />
                                <span class="text-danger small" asp-validation-for="vehiculo.Anio"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="vehiculo.Precio"></label>
                                <div class="input-group">
                                    <span class="input-group-text">₡</span>
                                    <input class="form-control"
                                           asp-for="vehiculo.Precio"
                                           type="number"
                                           step="0.01"
                                           min="0" />
                                </div>
                                <span class="text-danger small" asp-validation-for="vehiculo.Precio"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="vehiculo.Color"></label>
                                <input class="form-control" asp-for="vehiculo.Color" />
                                <span class="text-danger small" asp-validation-for="vehiculo.Color"></span>
                            </div>
                        </div>

                        <div class="form-section-title mt-4">Información del propietario</div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label" asp-for="vehiculo.CorreoPropietario"></label>
                                <input class="form-control"
                                       asp-for="vehiculo.CorreoPropietario"
                                       type="email" />
                                <span class="text-danger small" asp-validation-for="vehiculo.CorreoPropietario"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="vehiculo.TelefonoPropietario"></label>
                                <input class="form-control"
                                       asp-for="vehiculo.TelefonoPropietario"
                                       type="tel" />
                                <span class="text-danger small" asp-validation-for="vehiculo.TelefonoPropietario"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="text-danger small" asp-validation-summary="All"></div>
                        </div>

                        <div class="form-actions">
                            <a class="btn-form-secondary" asp-page="./Index">
                                <i class="bi bi-arrow-left-circle me-1"></i> Regresar
                            </a>

                            <button type="submit" class="btn-form-primary">
                                <i class="bi bi-save2 me-1"></i> Guardar cambios
                            </button>
                        </div>

                        <input type="hidden" asp-for="vehiculo.Id" />
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        async function fetchModelos() {
            const marcaId = document.getElementById('marcas').value;
            const modelosSelect = document.getElementById('modelos');

            if (!marcaId) {
                modelosSelect.innerHTML = '<option value="">Seleccione un modelo</option>';
                return;
            }

            modelosSelect.innerHTML = '<option value="">Cargando modelos...</option>';

            try {
                const response = await fetch(`?handler=ObtenerModelos&marcaId=${marcaId}`);
                if (!response.ok) throw new Error('Error obteniendo los datos');

                const modelos = await response.json();
                modelosSelect.innerHTML = '<option value="">Seleccione un modelo</option>';

                modelos.forEach(modelo => {
                    const option = document.createElement('option');
                    option.value = modelo.id;
                    option.text = modelo.nombre;
                    modelosSelect.appendChild(option);
                });
            } catch (error) {
                console.error('Error obteniendo los datos:', error);
                modelosSelect.innerHTML = '<option value="">No se pudieron cargar</option>';
            }
        }

        (function () {
            const placaInput = document.getElementById("placa");
            if (!placaInput) return;

            placaInput.addEventListener("input", () => {
                let v = (placaInput.value || "").toUpperCase().replace(/[^A-Z0-9]/g, "");

                const nums = v.slice(0, 3).replace(/\D/g, "");
                const letters = v.slice(3, 6).replace(/[^A-Z]/g, "");

                let out = nums;
                if (nums.length === 3) out += "-";
                out += letters;

                placaInput.value = out.slice(0, 7);
            });
        })();
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}